# macOS system files
.DS_Store
.AppleDouble
.LSOverride

# Mac resource fork files (appear as dot-underscore)
._*

# Hidden dot-underscore files like .__filename
.__*

# Compiled Python cache
__pycache__/
*.py[cod]

# Jupyter notebooks you don't want to track
getting_started.ipynb

# Project config you might want ignored
.pyproject.toml

# Backup or autosave files
*~
*.swp
*.swo
*.bak
*.tmp


# Ignore output directories
out/
out*/

# Ignore viewer files
viewer/

# Ignore specific output files
heavy_hex_local.slurm
heavy_hex.slurm
step1_generate_circuits.sh
step1_error_rate.sh
step2_collect_stats.sh
table.txt
